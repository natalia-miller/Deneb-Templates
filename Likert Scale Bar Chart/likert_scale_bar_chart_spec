  "transform": [
    {
      "calculate": "1 * 0",
      "as": "Zero"
    },
    {
      "calculate": "5 * 1",
      "as": "One"
    },
    {
      "stack": "Score",
      "as": [
        "v1",
        "v2"
      ],
      "groupby": [
        "Project",
        "Category"
      ]
    },
    {
      "calculate": "datum.v2-datum.v1",
      "as": "var"
    },
    {
      "calculate": "datum.var<0.065?datum.v1+0.09:datum.v2",
      "as": "v2_pos"
    },
    { 
      "calculate": "datum.v2 == 1 ? 'Terrible': datum.v2 == 2 ? 'Bad': datum.v2 == 3 ? 'Average': datum.v2 == 4 ? 'Good' : datum.v2 == 5 ? 'Excellent' : ''",
      "as": "rating"
    },
    {
      "calculate": "datum.v2 == 1 ? '#F27A7C': datum.v2 == 2 ? '#FCA927': datum.v2 == 3 ? '#FFCA0A': datum.v2 == 4 ? '#8AD2D1' : datum.v2 == 5 ? '#7EC99E' : ''",
      "as": "bar_color"
    }
  ],
